* {
    background: #1e1e2e;
    foreground: #cdd6f4;
    font: "Fira Sans 12";
}

window {
    border: 2px solid #89b4fa;
    border-radius: 8px;
    padding: 10px;
}
listview {
    lines: 5;
    fixed-height: 0;
    dynamic-width: 1;
}

element {
    padding: 8px;
    border-radius: 6px;
    margin: 4px 0;
}

